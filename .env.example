# ===================================
# Supabase Configuration
# ===================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Supabase Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (safe to expose in client)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===================================
# RevenueCat API Keys
# ===================================
# Get these from: https://app.revenuecat.com/

# Android API Key (Production - Google Play Store)
# From: https://app.revenuecat.com/ → API keys → Your App (Play Store)
REVENUECAT_ANDROID_API_KEY=your_android_key

# iOS API Key (when you add iOS support)
# From: https://app.revenuecat.com/ → API keys → Your App (App Store)
REVENUECAT_IOS_API_KEY=your_ios_key
