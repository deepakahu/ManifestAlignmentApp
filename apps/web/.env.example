# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key # Required for admin operations

# Mailgun Configuration
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
MAILGUN_FROM_EMAIL=Your App Name <postmaster@your_mailgun_domain>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth Configuration
NEXT_PUBLIC_AUTH_REDIRECT_URL=https://manifestationalarm.com/auth/callback
